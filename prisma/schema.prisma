generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Rol {
  ADMIN
  PROFESOR
  ALUMNO
}

model Usuario {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  nombre    String
  rol       Rol      @default(ALUMNO)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profesor Profesor?
  alumno   Alumno?
}

model Profesor {
  id        String   @id @default(cuid())
  usuarioId String   @unique
  dni       String   @unique
  telefono  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  usuario        Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  clases         Clase[]
  tareas         Tarea[]
  examenes       Examen[]
  seccionesTutor Seccion[]
  // ProfesorMateria eliminado: la relación Profesor↔Materia se deduce
  // via Clase (un profesor dicta una materia en una sección concreta).
}

// ─── Año Lectivo ─────────────────────────────────────────────────────────────
model AnoLectivo {
  id        String   @id @default(cuid())
  anio      Int      @unique
  activo    Boolean  @default(false)
  createdAt DateTime @default(now())

  secciones  Seccion[]
  matriculas Matricula[]
}

// ─── Estructura Académica ─────────────────────────────────────────────────────
enum TipoNivel {
  PRIMARIA
  SECUNDARIA
}

model Nivel {
  id        String    @id @default(cuid())
  nombre    String
  tipo      TipoNivel @unique
  createdAt DateTime  @default(now())

  grados   Grado[]
  criterio CriterioEvaluacion?
}

model CriterioEvaluacion {
  id               String   @id @default(cuid())
  nivelId          String   @unique
  pesoTareas       Int      @default(40)
  pesoExamenes     Int      @default(60)
  notaAprobatoria  Float    @default(10.5)
  updatedAt        DateTime @updatedAt

  nivel Nivel @relation(fields: [nivelId], references: [id], onDelete: Cascade)
}

model Grado {
  id               String   @id @default(cuid())
  nombre           String
  nivelId          String
  ordenSecuencia   Int      @default(0)
  gradoSiguienteId String?  @unique
  createdAt        DateTime @default(now())

  nivel          Nivel         @relation(fields: [nivelId], references: [id], onDelete: Cascade)
  gradoSiguiente Grado?        @relation("SecuenciaGrado", fields: [gradoSiguienteId], references: [id])
  gradoAnterior  Grado?        @relation("SecuenciaGrado")
  secciones      Seccion[]
  planEstudios   PlanEstudio[]

  @@unique([nivelId, nombre])
}

// ─── Catálogo de Materias ─────────────────────────────────────────────────────
// Una Materia existe UNA SOLA VEZ en el sistema, independientemente de en qué
// grados se dicte. La relación Materia↔Grado se define en PlanEstudio.
model Materia {
  id        String   @id @default(cuid())
  nombre    String   @unique
  area      String?  // "Ciencias", "Humanidades", "Arte" — agrupación opcional
  codigo    String?  @unique // "MAT", "COM" — útil para reportes y exportaciones
  createdAt DateTime @default(now())

  planEstudios PlanEstudio[]
}

// ─── Plan de Estudios ─────────────────────────────────────────────────────────
// Entidad intermedia que asigna una Materia a un Grado con metadatos curriculares.
// Reemplaza la relación directa Materia.gradoId del modelo anterior.
// Un PlanEstudio es la "materia-en-ese-grado": Matemáticas en 3er Grado Primaria
// es un PlanEstudio distinto de Matemáticas en 1er Grado Secundaria, aunque la
// Materia subyacente sea la misma fila.
model PlanEstudio {
  id             String   @id @default(cuid())
  gradoId        String
  materiaId      String
  horasSemanales Int      @default(0)
  orden          Int      @default(0)   // posición en la grilla horaria del grado
  obligatoria    Boolean  @default(true)
  observaciones  String?
  createdAt      DateTime @default(now())

  grado   Grado   @relation(fields: [gradoId], references: [id], onDelete: Cascade)
  materia Materia @relation(fields: [materiaId], references: [id], onDelete: Cascade)
  clases  Clase[]

  @@unique([gradoId, materiaId])
  @@index([gradoId])
  @@index([materiaId])
}

// ─── Sección ──────────────────────────────────────────────────────────────────
model Seccion {
  id              String   @id @default(cuid())
  nombre          String   // "A", "B", "C"
  gradoId         String
  anoLectivoId    String
  profesorTutorId String?
  createdAt       DateTime @default(now())

  grado         Grado      @relation(fields: [gradoId], references: [id], onDelete: Cascade)
  anoLectivo    AnoLectivo @relation(fields: [anoLectivoId], references: [id], onDelete: Cascade)
  profesorTutor Profesor?  @relation(fields: [profesorTutorId], references: [id], onDelete: SetNull)
  alumnos       Alumno[]
  clases        Clase[]

  @@unique([gradoId, anoLectivoId, nombre])
  @@index([anoLectivoId])
  @@index([profesorTutorId])
}

// ─── Clase ────────────────────────────────────────────────────────────────────
// Clase = PlanEstudio + Sección + Profesor.
// Referencia PlanEstudio (no Materia directamente) para heredar los metadatos
// curriculares (horasSemanales, orden, obligatoria) del plan del grado.
// Todos los alumnos de la Sección obtienen la Clase automáticamente.
model Clase {
  id            String   @id @default(cuid())
  planEstudioId String
  seccionId     String
  profesorId    String
  horario       String?
  salon         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  planEstudio PlanEstudio @relation(fields: [planEstudioId], references: [id], onDelete: Cascade)
  seccion     Seccion     @relation(fields: [seccionId], references: [id], onDelete: Cascade)
  profesor    Profesor    @relation(fields: [profesorId], references: [id], onDelete: Cascade)
  tareas      Tarea[]
  examenes    Examen[]

  @@unique([planEstudioId, seccionId])
  @@index([seccionId])
  @@index([profesorId])
}

// ─── Alumnos ──────────────────────────────────────────────────────────────────
enum EstadoAlumno {
  ACTIVO
  EGRESADO
  RETIRADO
}

model Alumno {
  id         String       @id @default(cuid())
  usuarioId  String       @unique
  dni        String       @unique
  seccionId  String?
  fechaNac   DateTime?
  anoIngreso Int
  estado     EstadoAlumno @default(ACTIVO)

  tutorDni      String?
  tutorNombre   String?
  tutorTelefono String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  usuario          Usuario           @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  seccion          Seccion?          @relation(fields: [seccionId], references: [id], onDelete: SetNull)
  matricula        Matricula?
  entregas         Entrega[]
  respuestasExamen RespuestaExamen[]

  @@index([seccionId])
  @@index([anoIngreso])
  @@index([estado])
}

// ─── Tareas ───────────────────────────────────────────────────────────────────
enum EstadoTarea {
  BORRADOR
  PUBLICADA
  CERRADA
}

model Tarea {
  id            String      @id @default(cuid())
  titulo        String
  descripcion   String?
  archivoUrl    String?
  archivoNombre String?
  fechaInicio   DateTime    @default(now())
  fechaLimite   DateTime
  estado        EstadoTarea @default(BORRADOR)
  profesorId    String
  claseId       String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  profesor Profesor  @relation(fields: [profesorId], references: [id], onDelete: Cascade)
  clase    Clase     @relation(fields: [claseId], references: [id], onDelete: Cascade)
  entregas Entrega[]

  @@index([claseId])
  @@index([profesorId])
  @@index([estado])
}

enum EstadoEntrega {
  PENDIENTE
  ENTREGADA
  CALIFICADA
  FUERA_DE_PLAZO
}

model Entrega {
  id            String        @id @default(cuid())
  tareaId       String
  alumnoId      String
  estado        EstadoEntrega @default(PENDIENTE)
  archivoUrl    String?
  archivoNombre String?
  nota          Float?
  comentario    String?
  fechaEntrega  DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  tarea  Tarea  @relation(fields: [tareaId], references: [id], onDelete: Cascade)
  alumno Alumno @relation(fields: [alumnoId], references: [id], onDelete: Cascade)

  @@unique([tareaId, alumnoId])
}

// ─── Exámenes ─────────────────────────────────────────────────────────────────
model Examen {
  id            String   @id @default(cuid())
  titulo        String
  descripcion   String?
  archivoUrl    String?
  archivoNombre String?
  fechaInicio   DateTime @default(now())
  fechaLimite   DateTime
  duracion      Int
  salon         String?
  profesorId    String
  claseId       String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  profesor   Profesor          @relation(fields: [profesorId], references: [id], onDelete: Cascade)
  clase      Clase             @relation(fields: [claseId], references: [id], onDelete: Cascade)
  respuestas RespuestaExamen[]

  @@index([claseId])
  @@index([profesorId])
}

enum EstadoRespuestaExamen {
  PENDIENTE
  ENTREGADO
  CALIFICADO
  FUERA_DE_PLAZO
}

model RespuestaExamen {
  id            String                @id @default(cuid())
  examenId      String
  alumnoId      String
  estado        EstadoRespuestaExamen @default(PENDIENTE)
  archivoUrl    String?
  archivoNombre String?
  nota          Float?
  comentario    String?
  fechaEntrega  DateTime?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  examen Examen @relation(fields: [examenId], references: [id], onDelete: Cascade)
  alumno Alumno @relation(fields: [alumnoId], references: [id], onDelete: Cascade)

  @@unique([examenId, alumnoId])
}

// ─── Matrículas ───────────────────────────────────────────────────────────────
enum EstadoMatricula {
  PENDIENTE
  PAGADO
  VENCIDO
}

enum MedioPago {
  EFECTIVO
  TRANSFERENCIA
  TARJETA
  YAPE
  PLIN
  OTRO
}

model Matricula {
  id               String          @id @default(cuid())
  alumnoId         String          @unique
  anoLectivoId     String
  monto            Float
  fechaVencimiento DateTime
  fechaPago        DateTime?
  medioPago        MedioPago?
  estado           EstadoMatricula @default(PENDIENTE)
  observaciones    String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  alumno     Alumno     @relation(fields: [alumnoId], references: [id], onDelete: Cascade)
  anoLectivo AnoLectivo @relation(fields: [anoLectivoId], references: [id])

  @@index([anoLectivoId])
}
